      { "keyword": "INT(x)", "diff": "取整函数" },
      { "keyword": "TYPE", "diff": "用户自定义类型（枚举、指针、记录）" },
      { "keyword": "DEFINE/SET", "diff": "集合定义" },
      { "keyword": ". (点号)", "diff": "记录字段访问，如 `rec.field`" },
      { "keyword": "^ (脱字符)", "diff": "指针解引用，如 `ptr^` 或 `^var`" },
      { "keyword": "ELSEIF", "diff": "多分支 IF 条件" },
      { "keyword": "ENDFOR", "diff": "A-Level 可使用 ENDFOR 结束 FOR 循环" },
      { "keyword": "APPEND", "diff": "追加写文件模式" },
      { "keyword": "RANDOM/SEEK/GETRECORD/PUTRECORD", "diff": "随机访问记录文件" },
      { "keyword": "CLASS", "diff": "面向对象类定义" },
