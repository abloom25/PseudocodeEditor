  "alevel-9618": {
    "extraKeywords": ["TYPE", "ENDTYPE", "DEFINE", "SET", "DATE", "APPEND", "RANDOM", "SEEK", "GETRECORD", "PUTRECORD", "CLASS", "ENDCLASS", "PUBLIC", "PRIVATE", "NEW", "INHERITS", "SUPER", "ELSEIF", "ENDFOR"],
    "extraFunctions": [
      { "name": "MID(string, start, length)", "desc": "提取子字符串" },
      { "name": "RIGHT(string, length)", "desc": "从右侧提取" },
      { "name": "RAND(x)", "desc": "0-x 随机数" },
      { "name": "INT(x)", "desc": "取整" }
    ],
    "extraControlStructures": [
      "WHILE condition ... ENDWHILE  // 无需 DO",
      "  value1 TO value2 : ...       // CASE 范围"
    ],
    "extraDeclarations": [
      "CONSTANT name = value  // 使用 = 而非 <-"
    ],
    "extraFunctionsProcedures": [
      "CALL ProcedureName(args)  // 必须使用 CALL"
    ],
    "userDefinedTypes": [
      "TYPE MyEnum = (Val1, Val2) ... ENDTYPE  // 枚举类型",
      "TYPE MyPtr = ^BaseType ... ENDTYPE       // 指针类型",
      "TYPE MyRecord ... ENDTYPE                 // 记录类型",
      "TYPE DateOfBirth : DATE                  // 日期类型",
      "  DECLARE field1 : TYPE",
      "  DECLARE field2 : TYPE",
      "DECLARE var : MyRecord                   // 声明记录变量",
      "DECLARE arr : ARRAY[1:10] OF MyRecord    // 记录数组",
      "var.field <- value                       // 字段访问赋值",
      "arr[i].field                              // 数组记录字段访问",
      "MyPtr <- ^var                            // 指针赋值（取地址）",
      "value <- MyPtr^                          // 指针解引用",
      "DEFINE MySet ('A','E') : LetterSet ... ENDTYPE  // 集合定义",
      "CLASS MyClass ... ENDCLASS                // 类定义",
      "PUBLIC/PRIVATE 成员                      // 访问控制",
      "object <- NEW MyClass(args)               // 创建对象",
      "object.Method(args)                       // 方法调用",
      "SUPER.Method(args)                        // 调用父类方法"
    ],
    "differences": [
      { "keyword": "CONSTANT", "diff": "使用 `=` 而非 `<-`" },
      { "keyword": "WHILE", "diff": "不使用 `DO`" },
      { "keyword": "CALL", "diff": "过程调用必须使用" },
