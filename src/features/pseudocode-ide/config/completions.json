{
  "common": {
    "keywords": [
      "DECLARE", "CONSTANT", "INPUT", "OUTPUT",
      "IF", "THEN", "ELSE", "ENDIF",
      "CASE", "OF", "OTHERWISE", "ENDCASE",
      "FOR", "TO", "STEP", "NEXT",
      "REPEAT", "UNTIL", "WHILE", "ENDWHILE",
      "PROCEDURE", "FUNCTION", "ENDPROCEDURE", "ENDFUNCTION",
      "RETURNS", "RETURN", "ARRAY",
      "OPENFILE", "CALL", "READFILE", "WRITEFILE", "CLOSEFILE",
      "TRUE", "FALSE", "AND", "OR", "NOT",
      "BYREF", "BYVAL", "READ", "WRITE",
      "TYPE", "ENDTYPE", "DEFINE", "SET"
    ],
    "typeKeywords": ["INTEGER", "REAL", "CHAR", "STRING", "BOOLEAN"],
    "functions": [
      "LENGTH", "LCASE", "UCASE", "ROUND", "DIV", "MOD", "EOF"
    ],
    "snippets": {
      "IF-THEN-ENDIF": {
        "body": ["IF ${1:condition} THEN", "\t${2:// statements}", "ENDIF"],
        "description": "IF-THEN-ENDIF statement"
      },
      "IF-THEN-ELSE-ENDIF": {
        "body": ["IF ${1:condition} THEN", "\t${2:// then branch}", "ELSE", "\t${3:// else branch}", "ENDIF"],
        "description": "IF-THEN-ELSE-ENDIF statement"
      },
      "FOR-TO-NEXT": {
        "body": ["FOR ${1:i} <- ${2:1} TO ${3:10}", "\t${4:// body}", "NEXT ${1:i}"],
        "description": "FOR-TO-NEXT loop"
      },
      "REPEAT-UNTIL": {
        "body": ["REPEAT", "\t${1:// body}", "UNTIL ${2:condition}"],
        "description": "REPEAT-UNTIL loop"
      },
      "FUNCTION": {
        "body": ["FUNCTION ${1:Name}(${2:param : TYPE}) RETURNS ${3:TYPE}", "\t${4:// body}", "\tRETURN ${5:value}", "ENDFUNCTION"],
        "description": "Function definition"
      },
      "PROCEDURE": {
        "body": ["PROCEDURE ${1:Name}(${2:param : TYPE})", "\t${3:// body}", "ENDPROCEDURE"],
        "description": "Procedure definition"
      },
      "DECLARE": {
        "body": ["DECLARE ${1:name} : ${2:INTEGER}"],
        "description": "Variable declaration"
      },
      "DECLARE-ARRAY": {
        "body": ["DECLARE ${1:name} : ARRAY[${2:1}:${3:10}] OF ${4:STRING}"],
        "description": "Array declaration"
      },
      "OPENFILE-READ": {
        "body": ["OPENFILE ${1:\"filename.txt\"} FOR READ"],
        "description": "Open file for reading"
      },
      "OPENFILE-WRITE": {
        "body": ["OPENFILE ${1:\"filename.txt\"} FOR WRITE"],
        "description": "Open file for writing"
      },
      "READFILE": {
        "body": ["READFILE ${1:\"filename.txt\"}, ${2:variable}"],
        "description": "Read from file"
      },
      "WRITEFILE": {
        "body": ["WRITEFILE ${1:\"filename.txt\"}, ${2:value}"],
        "description": "Write to file"
      },
      "CLOSEFILE": {
        "body": ["CLOSEFILE ${1:\"filename.txt\"}"],
        "description": "Close file"
      },
      "RETURN": {
        "body": ["RETURN ${1:value}"],
        "description": "Return statement"
      }
    }
  },
  "igcse-0478": {
    "extraKeywords": ["DO"],
    "extraFunctions": ["SUBSTRING", "RANDOM"],
    "extraSnippets": {
      "WHILE-DO-ENDWHILE": {
        "body": ["WHILE ${1:condition} DO", "\t${2:// body}", "ENDWHILE"],
        "description": "WHILE-DO-ENDWHILE loop"
      },
      "WHILE-EOF": {
        "body": ["WHILE NOT EOF(${1:\"filename.txt\"}) DO", "\t${2:// read and process file}", "ENDWHILE"],
        "description": "Read file until EOF"
      }
    }
  },
  "alevel-9618": {
    "extraKeywords": ["TYPE", "ENDTYPE", "DEFINE", "SET"],
    "extraFunctions": ["MID", "RIGHT", "RAND", "INT"],
    "extraSnippets": {
      "WHILE-ENDWHILE": {
        "body": ["WHILE ${1:condition}", "\t${2:// body}", "ENDWHILE"],
        "description": "WHILE-ENDWHILE loop (no DO)"
      },
      "WHILE-EOF": {
        "body": ["WHILE NOT EOF(${1:\"filename.txt\"})", "\t${2:// read and process file}", "ENDWHILE"],
        "description": "Read file until EOF"
      },
      "TYPE-ENUM": {
        "body": ["TYPE ${1:MyEnum} = (${2:Value1}, ${3:Value2}, ${4:Value3})", "ENDTYPE"],
        "description": "Enumerated type (A-Level)"
      },
      "TYPE-POINTER": {
        "body": ["TYPE ${1:MyPointer} = ^${2:BaseType}", "ENDTYPE"],
        "description": "Pointer type (A-Level)"
      },
      "TYPE-RECORD": {
        "body": ["TYPE ${1:MyRecord}", "\tDECLARE ${2:field1} : ${3:STRING}", "\tDECLARE ${4:field2} : ${5:INTEGER}", "ENDTYPE"],
        "description": "Record type (A-Level)"
      },
      "DEFINE-SET": {
        "body": ["DEFINE ${1:MySet} (${2:'A'}, ${3:'B'}, ${4:'C'}) : ${5:LetterSet}", "ENDTYPE"],
        "description": "Set definition (A-Level)"
      },
      "DECLARE-RECORD": {
        "body": ["DECLARE ${1:name} : ${2:MyRecord}"],
        "description": "Declare record variable (A-Level)"
      },
      "DECLARE-ARRAY-OF-RECORD": {
        "body": ["DECLARE ${1:name} : ARRAY[${2:1}:${3:10}] OF ${4:MyRecord}"],
        "description": "Declare array of record (A-Level)"
      }
    }
  }
}
